# Supabase (v2 전용 신규 프로젝트 — v1 DB와 완전 분리)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxx

# 로컬 개발 (supabase start 출력의 anon key — docker-compose가 참조)
SUPABASE_LOCAL_ANON_KEY=

# V-World 토지임야 정보 API
V_WORLD_LADFRLLIST=
V_WORLD_DOMAIN=

# 서버 핸들러용 service role(secret) key — supabase status의 Secret 값
SUPABASE_SERVICE_ROLE_KEY=

# v1 → v2 시드(pnpm seed:v1) 읽기 소스 — v1 운영 DB (anon, 읽기 전용)
# v1은 RLS DISABLED라 anon 키로 읽기 가능. 시드는 v1에 절대 쓰지 않는다.
V1_SUPABASE_URL=
V1_SUPABASE_ANON_KEY=
